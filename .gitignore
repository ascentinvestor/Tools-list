# Build output — published by Netlify
dist/

# Astro generated types
.astro/

# Dependencies
node_modules/

# OS & editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.qodo/

# Logs
*.log
npm-debug.log*

# Local Netlify folder
.netlify

# Playwright test results & reports
test-results/
playwright-report/

# Lighthouse — keep results.db but exclude SQLite temp files
lighthouse/*.db-wal
lighthouse/*.db-shm

# Claude workspace files (worktrees cause Netlify submodule errors)
.claude/

# Playwright capture script — browser profile contains session data
scripts/.browser-profile/
