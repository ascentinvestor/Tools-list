    <div class="info-box" style="margin-top:0">
      <h4>⚖️ Disclaimer</h4>
      <p>This calculator is for indicative purposes only based on publicly available tax rules. It does not account for all scenarios, exemptions, or individual circumstances. Consult a qualified CA / tax advisor for personalised advice. Rates reflect Finance Act 2025 (Budget 2025-26).</p>
    </div>
  </main>

  <script is:inline>
  (function(){
  const $ = id => document.getElementById(id);

  function fmtINR(n){
    return new Intl.NumberFormat('en-IN',{style:'currency',currency:'INR',minimumFractionDigits:0,maximumFractionDigits:0}).format(n);
  }
  function getNum(id){ return parseFloat($(id)?.value)||0; }

  /* ── Slab computation ── */
  function calcSlabs(taxable, slabs){
    let tax=0,prev=0;
    for(const {limit,rate} of slabs){
      if(taxable<=prev) break;
      tax+=(Math.min(taxable,limit)-prev)*rate;
      prev=limit;
    }
    return tax;
  }
  function surchargeAmt(tax, income, isNew){
    if(income>50000000) return isNew?tax*0.25:tax*0.37;
    if(income>20000000) return tax*0.25;
    if(income>10000000) return tax*0.15;
    if(income>5000000) return tax*0.10;
    return 0;
  }

  /* ── HRA ── */
  function calcHRA(){
    const hraReceived=getNum('inc-hra-received');
    const basic=getNum('hra-basic');
    const da=getNum('hra-da');
    const rent=getNum('hra-rent');
    const metro=$('hra-city').value==='metro';
    const r1=hraReceived;
    const r2=Math.max(0,rent-(basic+da)*0.10);
    const r3=(basic+da)*(metro?0.50:0.40);
    const exempt=Math.min(r1,r2,r3);
    $('hra-rule1').textContent=fmtINR(r1);
    $('hra-rule2').textContent=fmtINR(r2);
    $('hra-rule3').textContent=fmtINR(r3);
    $('hra-final').textContent=fmtINR(Math.round(exempt));
    $('hra-exempt-value')&&($('hra-exempt-value').textContent=fmtINR(Math.round(exempt)));
    return exempt;
  }

  /* ── Slab bar render ── */
  function renderSlabBars(containerId, slabs, taxable, color){
    const el=$(containerId); if(!el) return;
    el.innerHTML='';
    const maxTax=calcSlabs(taxable,slabs)||1;
    let prev=0;
    slabs.forEach(({limit,rate})=>{
      const bandIncome=Math.max(0,Math.min(taxable,limit)-prev);
      const bandTax=bandIncome*rate;
      prev=limit;
      if(bandIncome===0) return;
      const limitStr=limit===Infinity?'above':fmtINR(limit);
      const pct=Math.round((bandTax/maxTax)*100);
      el.innerHTML+=`<div class="slab-row">
        <span class="slab-label" style="font-size:0.75rem">₹${fmtINR(prev<Infinity?prev:0)}–${limit===Infinity?'above':fmtINR(limit)} (${(rate*100).toFixed(0)}%)</span>
        <div class="slab-bar-bg"><div class="slab-bar-fill" style="width:${pct}%;background:${color}"></div></div>
        <span class="slab-amount" style="color:${color}">${bandTax>0?fmtINR(Math.round(bandTax)):'—'}</span>
      </div>`;
    });
  }

  /* ── Bar chart ── */
  function drawBar(canvas, items){
    const dpr=window.devicePixelRatio||1;
    const w=canvas.parentElement.clientWidth-32;
    const h=260;
    canvas.width=w*dpr; canvas.height=h*dpr;
    canvas.style.width=w+'px'; canvas.style.height=h+'px';
    const ctx=canvas.getContext('2d'); ctx.scale(dpr,dpr);
    const pad={t:30,r:20,b:60,l:80};
    const cw=w-pad.l-pad.r, ch=h-pad.t-pad.b;
    const maxV=Math.max(...items.map(i=>i.v))||1;
    const adjMax=maxV*1.15;
    // grid
    ctx.strokeStyle='#f3f4f6'; ctx.lineWidth=1;
    for(let i=0;i<=5;i++){
      const y=pad.t+(ch*i/5);
      ctx.beginPath(); ctx.moveTo(pad.l,y); ctx.lineTo(pad.l+cw,y); ctx.stroke();
      const v=adjMax-(adjMax*i/5);
      ctx.fillStyle='#9ca3af'; ctx.font='10px Inter,sans-serif'; ctx.textAlign='right';
      const lbl=v>=100000?`₹${(v/100000).toFixed(1)}L`:`₹${(v/1000).toFixed(0)}K`;
      ctx.fillText(lbl,pad.l-6,pad.t+(ch*i/5)+4);
    }
    // bars
    const bw=Math.min(80,cw/items.length*0.55);
    const bs=cw/items.length;
    items.forEach((item,i)=>{
      const bh=(item.v/adjMax)*ch;
      const x=pad.l+bs*i+(bs-bw)/2;
      const y=pad.t+ch-bh;
      ctx.fillStyle=item.color; ctx.fillRect(x,y,bw,bh);
      // value label
      ctx.fillStyle='#374151'; ctx.font='bold 11px Inter,sans-serif'; ctx.textAlign='center';
      const lbl=item.v>=100000?`₹${(item.v/100000).toFixed(1)}L`:`₹${(item.v/1000).toFixed(0)}K`;
      ctx.fillText(lbl,x+bw/2,y-6);
      // x label
      ctx.fillStyle='#6b7280'; ctx.font='11px Inter,sans-serif';
      ctx.fillText(item.label,x+bw/2,pad.t+ch+18);
    });
  }

  /* ── Main compute ── */
  function compute(){
    const fy=$('tax-fy').value;
    const age=$('tax-age').value;
    const gross=getNum('inc-salary')+getNum('inc-rental')+getNum('inc-business')+getNum('inc-other');

    const hraExempt=calcHRA();

    // --- OLD regime ---
    const oldStd=50000;
    const old80c=Math.min(getNum('ded-80c'),150000);
    const old80d=Math.min(getNum('ded-80d'),age==='senior'||age==='super'?100000:50000);
    const oldNpsSelf=Math.min(getNum('ded-nps-self'),50000);
    const old80e=getNum('ded-80e');
    const old24b=Math.min(getNum('ded-24b'),200000);
    const old80tta=Math.min(getNum('ded-80tta'),age==='senior'?50000:10000);
    const oldPtax=getNum('ded-ptax');
    const oldNpsEmpl=getNum('ded-nps-employer');
    const oldDeds=oldStd+old80c+old80d+oldNpsSelf+old80e+old24b+old80tta+oldPtax+hraExempt+oldNpsEmpl;
    const oldTaxable=Math.max(0,gross-oldDeds);
    const basicExempt=age==='super'?500000:age==='senior'?300000:250000;
    const oldSlabs=[{limit:basicExempt,rate:0},{limit:500000,rate:0.05},{limit:1000000,rate:0.20},{limit:Infinity,rate:0.30}];
    let oldTax=calcSlabs(oldTaxable,oldSlabs);
    if(oldTaxable<=500000) oldTax=Math.max(0,oldTax-12500); // 87A
    const oldSC=surchargeAmt(oldTax,oldTaxable,false);
    const oldCess=(oldTax+oldSC)*0.04;
    const oldTotal=oldTax+oldSC+oldCess;

    // --- NEW regime ---
    const fyNum=parseInt(fy.split('-')[0]);
    const newStd=fyNum>=2024?75000:50000;
    const newNpsEmpl=getNum('ded-nps-employer');
    const newDeds=newStd+newNpsEmpl;
    const newTaxable=Math.max(0,gross-newDeds);
    const newSlabs=fyNum>=2025
      ? [{limit:400000,rate:0},{limit:800000,rate:0.05},{limit:1200000,rate:0.10},{limit:1600000,rate:0.15},{limit:2000000,rate:0.20},{limit:2400000,rate:0.25},{limit:Infinity,rate:0.30}]
      : fyNum===2024
      ? [{limit:300000,rate:0},{limit:700000,rate:0.05},{limit:1000000,rate:0.10},{limit:1200000,rate:0.15},{limit:1500000,rate:0.20},{limit:Infinity,rate:0.30}]
      : [{limit:300000,rate:0},{limit:600000,rate:0.05},{limit:900000,rate:0.10},{limit:1200000,rate:0.15},{limit:1500000,rate:0.20},{limit:Infinity,rate:0.30}];
    let newTax=calcSlabs(newTaxable,newSlabs);
    const rebateLimit=fyNum>=2025?1200000:700000;
    if(newTaxable<=rebateLimit) newTax=0;
    const newSC=surchargeAmt(newTax,newTaxable,true);
    const newCess=(newTax+newSC)*0.04;
    const newTotal=newTax+newSC+newCess;

    // update DOM
    $('old-gross').textContent=fmtINR(gross);
    $('old-deds').textContent=fmtINR(Math.round(oldDeds));
    $('old-taxable').textContent=fmtINR(Math.round(oldTaxable));
    $('old-tax').textContent=fmtINR(Math.round(oldTax));
    $('old-surcharge').textContent=fmtINR(Math.round(oldSC));
    $('old-cess').textContent=fmtINR(Math.round(oldCess));
    $('old-total').textContent=fmtINR(Math.round(oldTotal));
    $('new-gross').textContent=fmtINR(gross);
    $('new-deds').textContent=fmtINR(Math.round(newDeds));
    $('new-taxable').textContent=fmtINR(Math.round(newTaxable));
    $('new-tax').textContent=fmtINR(Math.round(newTax));
    $('new-surcharge').textContent=fmtINR(Math.round(newSC));
    $('new-cess').textContent=fmtINR(Math.round(newCess));
    $('new-total').textContent=fmtINR(Math.round(newTotal));

    // winner
    const cardOld=$('card-old'), cardNew=$('card-new');
    const banner=$('tax-summary-banner');
    const saving=Math.abs(oldTotal-newTotal);
    if(oldTotal<newTotal){
      cardOld.className='regime-card winner winner-old';
      cardNew.className='regime-card';
      banner.className='tax-summary old-wins';
      banner.querySelector('.tax-summary-left').innerHTML=`Old Regime is better for you<span>You save ${fmtINR(Math.round(saving))} by choosing Old Regime</span>`;
    } else if(newTotal<oldTotal){
      cardNew.className='regime-card winner winner-new';
      cardOld.className='regime-card';
      banner.className='tax-summary new-wins';
      banner.querySelector('.tax-summary-left').innerHTML=`New Regime is better for you<span>You save ${fmtINR(Math.round(saving))} by choosing New Regime</span>`;
    } else {
      cardOld.className='regime-card'; cardNew.className='regime-card';
      banner.className='tax-summary new-wins';
      banner.querySelector('.tax-summary-left').innerHTML=`Both regimes result in equal tax<span>Prefer New Regime for simplicity</span>`;
    }
    $('summary-saving').textContent=fmtINR(Math.round(saving));
    $('monthly-tds-old').textContent=fmtINR(Math.round(oldTotal/12));
    $('monthly-tds-new').textContent=fmtINR(Math.round(newTotal/12));

    // ETR
    const etrOld=gross>0?(oldTotal/gross)*100:0;
    const etrNew=gross>0?(newTotal/gross)*100:0;
    $('etr-old-pct').textContent=etrOld.toFixed(1)+'%';
    $('etr-new-pct').textContent=etrNew.toFixed(1)+'%';
    $('etr-bar-old').style.width=Math.min(100,etrOld*3)+'%';
    $('etr-bar-new').style.width=Math.min(100,etrNew*3)+'%';

    // charts
    drawBar($('tax-bar-chart'),[
      {label:'Old Regime',v:Math.round(oldTotal),color:'#4f46e5'},
      {label:'New Regime',v:Math.round(newTotal),color:'#059669'},
      {label:'Deductions (Old)',v:Math.round(oldDeds),color:'#6366f1'},
    ]);

    // slab bars
    renderSlabBars('old-slab-bars',oldSlabs,oldTaxable,'#4f46e5');
    renderSlabBars('new-slab-bars',newSlabs,newTaxable,'#059669');

    // capital gains
    const stcgEq=getNum('cg-stcg-equity');
    const stcgOth=getNum('cg-stcg-other');
    const ltcgEq=Math.max(0,getNum('cg-ltcg-equity')-125000);
    const ltcgOth=getNum('cg-ltcg-other');
    const taxStcgEq=stcgEq*0.20; // 20% post Budget 2024
    const taxStcgOth=stcgOth*(newTaxable>0?(newTotal/(newTaxable||1)):0); // slab
    const taxLtcgEq=ltcgEq*0.125;
    const taxLtcgOth=ltcgOth*0.125;
    const totalCG=taxStcgEq+taxStcgOth+taxLtcgEq+taxLtcgOth;
    $('cg-tax-stcg-eq').textContent=fmtINR(Math.round(taxStcgEq));
    $('cg-tax-stcg-oth').textContent=fmtINR(Math.round(taxStcgOth));
    $('cg-tax-ltcg-eq').textContent=fmtINR(Math.round(taxLtcgEq));
    $('cg-tax-ltcg-oth').textContent=fmtINR(Math.round(taxLtcgOth));
    $('cg-tax-total').textContent=fmtINR(Math.round(totalCG));
  }

  /* ── Accordion ── */
  window.toggleAcc=function(id){
    const body=$(id);
    const arr=$('arr-'+id);
    const open=body.classList.toggle('open');
    if(arr) arr.textContent=open?'▲':'▼';
  };

  /* ── Tabs ── */
  document.querySelectorAll('.tab-btn[data-tab]').forEach(btn=>{
    btn.addEventListener('click',function(){
      document.querySelectorAll('.tab-btn[data-tab]').forEach(b=>b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
      this.classList.add('active');
      $('tab-'+this.dataset.tab)?.classList.add('active');
      if(this.dataset.tab==='comparison') compute();
    });
  });

  /* ── Event listeners ── */
  document.querySelectorAll('input[type="number"],select').forEach(el=>{
    el.addEventListener('input',compute);
    el.addEventListener('change',compute);
  });

  compute();
