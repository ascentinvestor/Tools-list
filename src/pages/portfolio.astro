---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderMain from '../components/HeaderMain.astro';
import FooterMain from '../components/FooterMain.astro';
---
<BaseLayout
  title="Portfolio Tracker - AscentInvestor"
  description="Upload and track your mutual funds portfolio screenshots on a daily basis. Monitor your investment journey with AscentInvestor."
>
  <Fragment slot="head">
    <style is:global>

.title-section{text-align:center;margin-bottom:2rem;position:relative;padding:4rem 0;background:linear-gradient(135deg,#10b981 0%,#059669 50%,#047857 100%);border-radius:1rem;color:white;overflow:hidden}
        .title-section::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");opacity:0.3}
        .title-section *{position:relative;z-index:1}
        @media (min-width:640px){.title-section{margin-bottom:3rem;padding:5rem 0}}
        .title{font-size:2.25rem;font-weight:700;color:white;margin-bottom:1rem;text-shadow:0 2px 4px rgba(0,0,0,0.3)}
        @media (min-width:640px){.title{font-size:3rem}}
        @media (min-width:768px){.title{font-size:3.75rem}}
        .subtitle{font-size:1.125rem;color:rgba(255,255,255,0.9);max-width:42rem;margin:0 auto;text-shadow:0 1px 2px rgba(0,0,0,0.2)}
        .upload-section{background:white;padding:2rem;border-radius:0.75rem;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);margin-bottom:2rem;display:none}
        .upload-section.admin-only{display:block}
        .admin-badge{position:fixed;bottom:1rem;right:1rem;background:#4f46e5;color:white;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:100}
        .admin-login-btn{background:#4f46e5;color:white;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;border:none;cursor:pointer;position:fixed;bottom:1rem;right:1rem;box-shadow:0 4px 6px rgba(0,0,0,0.1);z-index:100}
        .admin-login-btn:hover{background:#4338ca}
        .upload-area{border:2px dashed #d1d5db;border-radius:0.75rem;padding:3rem 2rem;text-align:center;transition:all 0.3s ease;background:#f9fafb}
        .upload-area:hover{border-color:#4f46e5;background:#f3f4f6}
        .upload-area.dragover{border-color:#4f46e5;background:#eef2ff}
        .upload-icon{width:4rem;height:4rem;margin:0 auto 1rem;color:#9ca3af}
        .upload-text{font-size:1.125rem;font-weight:600;color:#111827;margin-bottom:0.5rem}
        .upload-subtext{color:#6b7280;margin-bottom:1.5rem}
        .upload-btn{background:#4f46e5;color:white;padding:0.75rem 1.5rem;border-radius:0.5rem;font-weight:600;border:none;cursor:pointer;transition:background 0.2s}
        .upload-btn:hover{background:#4338ca}
        .file-input{display:none}
        .portfolio-grid{display:grid;grid-template-columns:1fr;gap:1.5rem}
        @media (min-width:768px){.portfolio-grid{grid-template-columns:repeat(2,1fr)}}
        @media (min-width:1024px){.portfolio-grid{grid-template-columns:repeat(3,1fr)}}
        .portfolio-card{background:white;border-radius:0.75rem;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);overflow:hidden;transition:all 0.3s ease}
        .portfolio-card:hover{transform:translateY(-4px);box-shadow:0 10px 15px -3px rgba(0,0,0,0.1)}
        .portfolio-image{width:100%;height:16rem;object-fit:contain;background:#f3f4f6;image-rendering:-webkit-optimize-contrast;image-rendering:crisp-edges;image-rendering:high-quality}
        .portfolio-info{padding:1rem}
        .portfolio-date{font-weight:600;color:#111827;margin-bottom:0.5rem}
        .portfolio-actions{display:flex;gap:0.5rem}
        .action-btn{padding:0.5rem 1rem;border-radius:0.375rem;font-size:0.875rem;font-weight:500;border:none;cursor:pointer;transition:all 0.2s}
        .view-btn{background:#10b981;color:white}
        .view-btn:hover{background:#059669}
        .delete-btn{background:#ef4444;color:white}
        .delete-btn:hover{background:#dc2626}
        .empty-state{text-align:center;padding:4rem 2rem;color:#6b7280}
        .empty-icon{width:6rem;height:6rem;margin:0 auto 1rem;color:#d1d5db}
        
        
        .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:1000;justify-content:center;align-items:center;padding:1rem}
        .modal.active{display:flex}
        .modal-content{background:white;border-radius:0.75rem;max-width:90%;max-height:90%;overflow:auto;position:relative}
        .modal-close{position:absolute;top:1rem;right:1rem;background:white;border-radius:50%;width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.2);z-index:1}
        .modal-close:hover{background:#f3f4f6}
        .modal-image{width:100%;height:auto;display:block;image-rendering:-webkit-optimize-contrast;image-rendering:crisp-edges;image-rendering:high-quality;max-width:100%;object-fit:contain}
    
    </style>
  </Fragment>
  <HeaderMain navCurrent="portfolio" />
<!-- Main Content -->
    <main id="main-content" role="main" class="container main">
        <!-- Title Section -->
        <div class="title-section">
            <h1 class="title">Portfolio Tracker</h1>
            <p class="subtitle">Upload and track your mutual funds portfolio screenshots. Monitor your investment journey over time.</p>
        </div>

        <!-- Upload Section (Admin Only) -->
        <section class="upload-section" id="uploadSection">
            <div class="upload-area" id="uploadArea">
                <svg class="upload-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                </svg>
                <p class="upload-text">Upload Portfolio Screenshot (Admin Only)</p>
                <p class="upload-subtext">Drag and drop or click to browse</p>
                <button class="upload-btn" onclick="document.getElementById('fileInput').click()">Choose File</button>
                <input type="file" id="fileInput" class="file-input" accept="image/*" multiple>
            </div>
        </section>

        <!-- Portfolio Gallery -->
        <section id="portfolioGallery">
            <!-- Portfolio cards will be dynamically added here -->
        </section>
    </main>

    <!-- Image Modal -->
    <div id="imageModal" class="modal">
        <div class="modal-content">
            <div class="modal-close" onclick="closeModal()">
                <svg style="width:1.5rem;height:1.5rem" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
            <img id="modalImage" class="modal-image" src="" alt="Portfolio Screenshot">
        </div>
    </div>

    <!-- Admin Controls -->
    <button id="adminLoginBtn" class="admin-login-btn" onclick="toggleAdminMode()">Admin Login</button>
    <div id="adminBadge" class="admin-badge" style="display:none">
        Admin Mode | <a href="#" onclick="logoutAdmin(); return false;" style="color:white;text-decoration:underline">Logout</a>
    </div><!-- JavaScript -->
    <script>
        // Admin password (in production, use proper backend authentication)
        const ADMIN_PASSWORD = 'ascentinvestor2026';
        
        // Check if user is admin
        function isAdmin() {
            return localStorage.getItem('isAdmin') === 'true';
        }

        // Toggle admin mode
        function toggleAdminMode() {
            if (isAdmin()) {
                logoutAdmin();
            } else {
                const password = prompt('Enter admin password:');
                if (password === ADMIN_PASSWORD) {
                    localStorage.setItem('isAdmin', 'true');
                    updateAdminUI();
                    renderPortfolio();
                    alert('Admin access granted!');
                } else if (password !== null) {
                    alert('Incorrect password!');
                }
            }
        }

        // Logout admin
        function logoutAdmin() {
            localStorage.removeItem('isAdmin');
            updateAdminUI();
            renderPortfolio();
            alert('Logged out from admin mode');
        }

        // Update UI based on admin status
        function updateAdminUI() {
            const adminBtn = document.getElementById('adminLoginBtn');
            const adminBadge = document.getElementById('adminBadge');
            const uploadSection = document.getElementById('uploadSection');
            
            if (isAdmin()) {
                adminBtn.style.display = 'none';
                adminBadge.style.display = 'block';
                uploadSection.classList.add('admin-only');
            } else {
                adminBtn.style.display = 'block';
                adminBadge.style.display = 'none';
                uploadSection.classList.remove('admin-only');
            }
        }
        
        // Initialize portfolio storage with pre-loaded portfolio from 28 Jan 2026
        let portfolioData = JSON.parse(localStorage.getItem('portfolioData')) || [];
        
        // Check if we need to add the 28 Jan 2026 portfolio
        const jan28Portfolio = {
            id: 'portfolio-28-jan-2026',
            date: '2026-01-28T00:00:00.000Z',
            image: 'portfolio-28-jan-2026.png',
            name: 'Mutual Fund Portfolio - 28 Jan 2026',
            isExternal: true // Flag to indicate this is an external file reference
        };
        
        // Add if not already present
        if (!portfolioData.find(p => p.id === 'portfolio-28-jan-2026')) {
            portfolioData.unshift(jan28Portfolio);
            localStorage.setItem('portfolioData', JSON.stringify(portfolioData));
        }

        // Load existing portfolio on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateAdminUI();
            renderPortfolio();
        });

        // File input change event
        document.getElementById('fileInput').addEventListener('change', function(e) {
            if (isAdmin()) {
                handleFiles(e.target.files);
            } else {
                alert('Admin access required to upload files');
                e.target.value = '';
            }
        });

        // Drag and drop functionality
        const uploadArea = document.getElementById('uploadArea');

        uploadArea.addEventListener('dragover', function(e) {
            if (isAdmin()) {
                e.preventDefault();
                uploadArea.classList.add('dragover');
            }
        });

        uploadArea.addEventListener('dragleave', function(e) {
            if (isAdmin()) {
                e.preventDefault();
                uploadArea.classList.remove('dragover');
            }
        });

        uploadArea.addEventListener('drop', function(e) {
            if (isAdmin()) {
                e.preventDefault();
                uploadArea.classList.remove('dragover');
                handleFiles(e.dataTransfer.files);
            } else {
                e.preventDefault();
                alert('Admin access required to upload files');
            }
        });

        // Handle file upload
        function handleFiles(files) {
            if (!isAdmin()) {
                alert('Admin access required to upload files');
                return;
            }
            
            for (let file of files) {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const portfolioItem = {
                            id: Date.now() + Math.random(),
                            date: new Date().toISOString(),
                            image: e.target.result,
                            name: file.name
                        };
                        portfolioData.unshift(portfolioItem);
                        localStorage.setItem('portfolioData', JSON.stringify(portfolioData));
                        renderPortfolio();
                    };
                    reader.readAsDataURL(file);
                }
            }
        }

        // Render portfolio gallery
        function renderPortfolio() {
            const gallery = document.getElementById('portfolioGallery');
            
            if (portfolioData.length === 0) {
                gallery.innerHTML = `
                    <div class="empty-state">
                        <svg class="empty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <h3 style="font-size:1.25rem;font-weight:600;margin-bottom:0.5rem">No Portfolio Screenshots Yet</h3>
                        <p>Upload your first portfolio screenshot to start tracking your investment journey.</p>
                    </div>
                `;
                return;
            }

            const adminMode = isAdmin();
            gallery.innerHTML = `<div class="portfolio-grid">${portfolioData.map(item => `
                <div class="portfolio-card">
                    <img src="${item.image}" alt="Portfolio ${new Date(item.date).toLocaleDateString()}" class="portfolio-image">
                    <div class="portfolio-info">
                        <p class="portfolio-date">${formatDate(item.date)}</p>
                        <div class="portfolio-actions">
                            <button class="action-btn view-btn" onclick="viewImage('${item.id}')">View Full</button>
                            ${adminMode ? `<button class="action-btn delete-btn" onclick="deleteImage('${item.id}')">Delete</button>` : ''}
                        </div>
                    </div>
                </div>
            `).join('')}</div>`;
        }

        // Format date
        function formatDate(dateString) {
            const date = new Date(dateString);
            const options = { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric'
            };
            // For the specific 28 Jan 2026 entry, return custom format
            if (dateString === '2026-01-28T00:00:00.000Z') {
                return '28 Jan 2026 - Mutual Fund Portfolio';
            }
            return date.toLocaleDateString('en-US', options);
        }

        // View image in modal
        function viewImage(id) {
            const item = portfolioData.find(p => p.id == id);
            if (item) {
                document.getElementById('modalImage').src = item.image;
                document.getElementById('imageModal').classList.add('active');
            }
        }

        // Close modal
        function closeModal() {
            document.getElementById('imageModal').classList.remove('active');
        }

        // Close modal on background click
        document.getElementById('imageModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        // Delete image
        function deleteImage(id) {
            if (!isAdmin()) {
                alert('Admin access required to delete portfolios');
                return;
            }
            
            if (confirm('Are you sure you want to delete this portfolio screenshot?')) {
                portfolioData = portfolioData.filter(p => p.id != id);
                localStorage.setItem('portfolioData', JSON.stringify(portfolioData));
                renderPortfolio();
            }
        }
    </script><!-- AdSense Ad Unit -->
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-4584710287882818" data-ad-slot="4101651637" data-ad-format="auto" data-full-width-responsive="true"></ins>
  <FooterMain />
</BaseLayout>
